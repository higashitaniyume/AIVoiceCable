<UserControl x:Class="AIVoiceCable.Views.CustomReplyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="自定义回复" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                    <StackPanel Width="260">
                        <TextBlock Text="声色" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding VoiceProfiles}" SelectedItem="{Binding SelectedVoice}" DisplayMemberPath="Name" />
                    </StackPanel>
                    <StackPanel Width="220" Margin="12,0,0,0">
                        <TextBlock Text="Fish Audio 模型" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding FishAudioModels}" SelectedItem="{Binding SelectedModel}" />
                    </StackPanel>
                </StackPanel>

                <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Button Content="试听" Command="{Binding PreviewCommand}" />
                    <Button Content="发送到 VB-CABLE" Command="{Binding SendToCableCommand}" />
                    <Button Content="保存为音频文件" Command="{Binding SaveAudioFileCommand}" />
                    <Button Content="停止播放" Command="{Binding StopPlaybackCommand}" />
                    <Button Content="清空文本" Command="{Binding ClearTextCommand}" />
                </WrapPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#31405A" />
                    <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="420"
                         FontSize="14" />
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="历史记录">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="历史音频文件" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding ActiveHistoryAudioPaths}" SelectedItem="{Binding SelectedHistoryAudioPath}" />
                    <Button Content="从历史记录复用" Command="{Binding ReuseHistoryCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding History}" SelectedItem="{Binding SelectedHistoryItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding VoiceProfileName, StringFormat=声色：{0}}" Foreground="#5E6A7D" />
                                <TextBlock Text="{Binding AudioCount, StringFormat=音频文件：{0} 个}" Foreground="#5E6A7D" />
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>
