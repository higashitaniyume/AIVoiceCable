<UserControl x:Class="AIVoiceCable.Views.ApiSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:AIVoiceCable.Behaviors">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <GroupBox Header="Fish Audio">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="API Key" FontWeight="SemiBold" />
                        <PasswordBox behaviors:PasswordBoxBinding.BoundPassword="{Binding FishAudioApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8,6" />
                        <TextBlock Text="API Base URL" FontWeight="SemiBold" />
                        <TextBox Text="{Binding FishAudioBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="默认模型" FontWeight="SemiBold" />
                        <TextBox Text="{Binding FishAudioDefaultModel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="失败回退模型" FontWeight="SemiBold" />
                        <TextBox Text="{Binding FishAudioFallbackModel, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="AssemblyAI 实时转录">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="API Key" FontWeight="SemiBold" />
                        <PasswordBox behaviors:PasswordBoxBinding.BoundPassword="{Binding AssemblyAiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="WebSocket Endpoint" FontWeight="SemiBold" />
                        <TextBox Text="{Binding AssemblyAiEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="LLM 服务商">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <ListBox ItemsSource="{Binding LlmProviders}" SelectedItem="{Binding SelectedProvider}" DisplayMemberPath="Name" Height="220" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="新增" Command="{Binding AddProviderCommand}" />
                            <Button Content="删除" Command="{Binding DeleteProviderCommand}" />
                            <Button Content="设为默认" Command="{Binding SetDefaultProviderCommand}" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="服务商名称" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProvider.Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Base URL" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProvider.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="模型" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProvider.Model, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="API Key" FontWeight="SemiBold" />
                        <PasswordBox behaviors:PasswordBoxBinding.BoundPassword="{Binding SelectedProviderApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="8,6" />
                        <TextBlock Text="系统提示词" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProvider.SystemPrompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="88" TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Temperature" FontWeight="SemiBold" />
                                <TextBox Text="{Binding SelectedProvider.Temperature, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Max Tokens" FontWeight="SemiBold" />
                                <TextBox Text="{Binding SelectedProvider.MaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Top P" FontWeight="SemiBold" />
                                <TextBox Text="{Binding SelectedProvider.TopP, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal">
                <Button Content="保存设置" Command="{Binding SaveCommand}" />
                <Button Content="测试 LLM" Command="{Binding TestLlmCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#31405A" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
