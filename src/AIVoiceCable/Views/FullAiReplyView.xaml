<UserControl x:Class="AIVoiceCable.Views.FullAiReplyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <GroupBox DockPanel.Dock="Top" Header="控制">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="开始完全 AI 回复" Command="{Binding StartCommand}" />
                    <Button Content="停止" Command="{Binding StopCommand}" />
                    <Button Content="暂停监听" Command="{Binding PauseListeningCommand}" />
                    <Button Content="清空上下文" Command="{Binding ClearContextCommand}" />
                    <Button Content="刷新设备" Command="{Binding RefreshDevicesCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="测试 ASR" Command="{Binding TestAsrCommand}" />
                    <Button Content="测试 LLM" Command="{Binding TestLlmCommand}" />
                    <Button Content="测试 TTS" Command="{Binding TestTtsCommand}" />
                    <Button Content="测试播放到 VB-CABLE" Command="{Binding TestPlaybackCommand}" />
                </StackPanel>
                <TextBlock Text="监听来源播放设备" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding RenderDevices}" SelectedItem="{Binding SelectedCaptureRenderDevice}" DisplayMemberPath="DisplayName" />
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#31405A" />
            </StackPanel>
        </GroupBox>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="状态" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding State}" FontSize="22" FontWeight="SemiBold" />
                    <CheckBox Content="运行中" IsChecked="{Binding IsRunning}" IsEnabled="False" Margin="0,12,0,4" />
                    <CheckBox Content="暂停监听" IsChecked="{Binding IsPaused}" IsEnabled="False" />
                    <TextBlock Text="按应用捕获为实验功能，当前主流程使用稳定的设备级 WASAPI loopback。" TextWrapping="Wrap" Margin="0,16,0,0" />
                </StackPanel>
            </GroupBox>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <GroupBox Header="Partial Transcript">
                    <TextBox Text="{Binding PartialTranscript}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </GroupBox>
                <GroupBox Grid.Row="1" Header="Final Transcript">
                    <TextBox Text="{Binding FinalTranscript}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </GroupBox>
                <GroupBox Grid.Row="2" Header="AI 回复">
                    <TextBox Text="{Binding AiReply}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
